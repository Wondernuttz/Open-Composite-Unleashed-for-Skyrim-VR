# British English keyboard

width 15

# Function key row (F1-F12 + ESC at top left)
key \e \e 0 0 1.5 1
.label ESC

key \f1 \f1 1.5 0 1.05 1
.label F1
key \f2 \f2 2.55 0 1.05 1
.label F2
key \f3 \f3 3.6 0 1.05 1
.label F3
key \f4 \f4 4.65 0 1.05 1
.label F4
key \f5 \f5 5.7 0 1.05 1
.label F5
key \f6 \f6 6.75 0 1.05 1
.label F6
key \f7 \f7 7.8 0 1.05 1
.label F7
key \f8 \f8 8.85 0 1.05 1
.label F8
key \f9 \f9 9.9 0 1.05 1
.label F9
key \f10 \f10 10.95 0 1.15 1
.label F10
key \f11 \f11 12.1 0 1.15 1
.label F11
key \f12 \f12 13.25 0 1.05 1
.label F12

# Number row
key ` ¬ 0 1
bank 1234567890-= !"£$%^&*()_+
key \b \b
.label back
.spans_to_right true

# QWERTY row
key \t \t 0 2 1.5 1
.label tab
key q Q 1.5 2
bank wertyuiop[] WERTYUIOP{}

# ASDF row
key \c \c 0 3 1.83 1
.label caps
key a A
bank sdfghjkl;'# SDFGHJKL:@~

# Enter
key \n \n 13.5 2
.label entr
.spans_to_right true
key \v \v 13.83 3
.label [T]
.spans_to_right true

# ZXCV row
key \z \z 0 4 1.5 1
.label shift

key \\ | 1.5 4
bank zxcvbnm,./ ZXCVBNM<>?

key \z \z 12.5 4
.label shift
.spans_to_right false

# Bottom row (spacebar + arrows + done)
key \s \z 1.5 5 6.5 1
.label

key \L \L 8 5 1 1
.label LT

key \D \D 9 5 1 1
.label DN

key \U \U 10 5 1 1
.label UP

key \R \R 11 5 1 1
.label RT

key \q \q 12 5 3 1
.label done
.spans_to_right true
