// ============================================================================
// SECTION 3: Quest 3 orientation transforms (was in LoadRenderModel_Async ~line 231)
// ============================================================================
#if 0

// Quest 3 controller orientation - different grip angle than Quest 2/Touch
if (isQuest3) {
	float scale = 1.65f;
	vec3 gripCenter(sided * 0.029f, -0.025f, 0.0f);
	float tiltRad = -80.0f * math_pi / 180.0f;
	vec3 verticalDrop(0.0f, -0.028f, 0.010f);
	transform = glm::translate(verticalDrop)
	    * glm::scale(vec3(scale))
	    * glm::rotate(tiltRad, vec3(1.0f, 0.0f, 0.0f))
	    * glm::translate(gripCenter);
}

#endif

// ============================================================================
// SECTION 4: Quest 3 UV coordinate handling (was in OBJ parser ~line 272)
// ============================================================================
#if 0

// Blender exports UVs with Y flipped compared to Maya
// Quest 3 models exported from Blender need this flip
if (isQuest3) {
	y = 1.0f - y;
}

#endif

// ============================================================================
// SECTION 5: Quest 3 texture ID assignment (was after model load ~line 336)
// ============================================================================
#if 0

// Assign Quest 3 specific texture IDs so LoadTexture_Async can find the right PNG
if (isQuest3) {
	rm.diffuseTextureId = (sided == 1) ? Q3_TEX_ID_LEFT : Q3_TEX_ID_RIGHT;
	OOVR_LOGF("Quest 3 model loaded: %s, textureId=%d, verts=%u, tris=%u",
	    pchRenderModelName, rm.diffuseTextureId, rm.unVertexCount, rm.unTriangleCount);
}

#endif

// ============================================================================
// SECTION 6: Quest 3 PNG texture loading (was in LoadTexture_Async ~line 360)
// ============================================================================
#if 0

// Load Quest 3 controller PNG textures from embedded resources
if (textureId == Q3_TEX_ID_LEFT || textureId == Q3_TEX_ID_RIGHT) {
	int rid = (textureId == Q3_TEX_ID_LEFT) ? RES_O_CTRL_Q3_LEFT : RES_O_CTRL_Q3_RIGHT;
	std::vector<unsigned char> pngPixels;
	unsigned pw, ph;
	if (loadAndDecodePng(rid, pngPixels, pw, ph)) {
		tx.unWidth = (uint16_t)pw;
		tx.unHeight = (uint16_t)ph;
		uint8_t* d = new uint8_t[pw * ph * 4];
		memcpy(d, pngPixels.data(), pw * ph * 4);
		tx.rubTextureMapData = d;
		tx.format = VRRenderModelTextureFormat_RGBA8_SRGB;
		tx.unMipLevels = 1;
		OOVR_LOGF("Quest 3 texture loaded: %ux%u, textureId=%d", pw, ph, textureId);
		return VRRenderModelError_None;
	} else {
		OOVR_LOGF("Failed to decode Quest 3 PNG for textureId=%d", textureId);
	}
}

#endif

// ============================================================================
// SECTION 7: Quest 3 D3D11 texture loading (was in LoadIntoTextureD3D11_Async ~line 425)
// ============================================================================
#if 0

// Direct D3D11 texture upload for Quest 3 PNG textures
if (textureId == Q3_TEX_ID_LEFT || textureId == Q3_TEX_ID_RIGHT) {
	int rid = (textureId == Q3_TEX_ID_LEFT) ? RES_O_CTRL_Q3_LEFT : RES_O_CTRL_Q3_RIGHT;
	std::vector<unsigned char> pngPixels;
	unsigned pw, ph;
	if (loadAndDecodePng(rid, pngPixels, pw, ph)) {
		// Resize/resample to match dest texture dimensions if needed
		if (pw != desc.Width || ph != desc.Height) {
			OOVR_LOGF("Quest 3 PNG %ux%u doesn't match dest %ux%u, using flat color fallback",
			    pw, ph, desc.Width, desc.Height);
		} else {
			// Direct copy - PNG is already RGBA8
			pix_t* pixels = new pix_t[px_count];
			memcpy(pixels, pngPixels.data(), px_count * sizeof(pix_t));

			int count = desc.MipLevels * desc.ArraySize;
			D3D11_SUBRESOURCE_DATA* init = new D3D11_SUBRESOURCE_DATA[count];
			for (int i = 0; i < count; i++) {
				init[i] = { pixels, desc.Width * (uint32_t)sizeof(uint32_t), 0 };
			}

			ID3D11Texture2D* tempTex;
			OOVR_FAILED_DX_ABORT(device->CreateTexture2D(&desc, init, &tempTex));
			context->CopyResource(output, tempTex);

			tempTex->Release();
			delete[] init;
			delete[] pixels;
			context->Release();
			device->Release();

			OOVR_LOGF("Quest 3 D3D11 texture uploaded: %ux%u", desc.Width, desc.Height);
			return VRRenderModelError_None;
		}
	}
}

#endif

