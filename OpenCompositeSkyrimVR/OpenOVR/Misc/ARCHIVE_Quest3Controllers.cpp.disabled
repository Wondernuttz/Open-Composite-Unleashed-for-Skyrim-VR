#if 0

// [EXPERIMENTAL] Quest 3 controller textures
// Disabled: Skyrim VR's IVRRenderModels shader doesn't apply UV-mapped
// textures, rendering Quest 3 controllers as black silhouettes.
static constexpr int Q3_TEX_ID_LEFT = 1000;
static constexpr int Q3_TEX_ID_RIGHT = 1001;

static bool loadAndDecodePng(int rid, std::vector<unsigned char>& pixels, unsigned& width, unsigned& height)
{
	string pngData = loadResource(rid, RES_T_PNG);
	if (pngData.empty())
		return false;
	unsigned error = lodepng::decode(pixels, width, height, (const unsigned char*)pngData.data(), pngData.size(), LCT_RGBA, 8);
	return error == 0;
}

#endif

// ============================================================================
// SECTION 2: Quest 3 model detection (was in LoadRenderModel_Async ~line 190)
// ============================================================================
#if 0

// Enable Quest 3 controller models via config
bool isQuest3 = oovr_global_configuration.ControllerModel() == "quest3";

// Would need to add Quest 3 model resources to resources.h:
